<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window while the process is starting when the OS's Dark Mode setting is off -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <!-- Show a splash screen on the activity. Automatically removed when
             the Flutter engine draws its first frame -->
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <!-- Theme applied to the Android Window as soon as the process has started.
         This theme determines the color of the Android Window while your
         Flutter UI initializes, as well as behind your Flutter UI while its
         running.

         This Theme is only used starting with V2 of Flutter's Android embedding. -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>

    <!-- Required by the MyPOS Slave SDK. `OperationActivity` (which the SDK
         launches for TWINT via `openPaymentActivity`) extends
         AppCompatActivity and must therefore inherit from an AppCompat
         theme — otherwise the activity crashes with
         IllegalStateException("You need to use a Theme.AppCompat theme").
         Pre-fix this style was missing AND OperationActivity wasn't
         declared in AndroidManifest; the manifest fix won't help on its
         own without this theme. -->
    <!-- MyPOS OperationActivity extends AppCompatActivity, so it must run with
         an AppCompat theme. Without this override the direct TWINT Activity
         diagnostic can crash immediately on launch.
         IMPORTANT: AppCompat themes look up BOTH the AppCompat-namespace
         attribute (windowNoTitle) AND the android-namespace one
         (android:windowNoTitle). Production sets both to be safe — copied
         verbatim from 2tech Service App. -->
    <style name="MyPosOperationTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
    </style>
</resources>
