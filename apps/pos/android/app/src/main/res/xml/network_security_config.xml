<?xml version="1.0" encoding="utf-8"?>
<!--
    GastroCore POS – Android Network Security Configuration
    https://developer.android.com/training/articles/security-config

    Cleartext (HTTP) is allowed because the POS talks to several LAN-only
    services that have no TLS endpoint:
      - LAN POS server (sync between tablets on the same restaurant Wi-Fi)
      - Network printers (most ESC/POS printers are HTTP-only)
      - EcoCash V4.2 cash collector kiosk (HTTP API on port 8080)
    These are private RFC1918 ranges behind the restaurant's router — not
    reachable from the public internet. The system trust store still
    handles TLS for any public endpoint the app may call.
-->
<network-security-config>

    <!-- LAN-friendly: cleartext permitted so private-IP services keep working. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <!-- Trust the system CA store (includes Let's Encrypt, DigiCert, etc.) -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!--
        To add certificate pinning for your production server, add a block like:

        <domain-config>
            <domain includeSubdomains="true">pos.example.com</domain>
            <pin-set>
                <pin digest="SHA-256">AAAA...base64-encoded-SPKI-hash==</pin>
                <pin digest="SHA-256">BBBB...backup-pin==</pin>
            </pin-set>
        </domain-config>

        Generate the pin with:
          openssl s_client -connect pos.example.com:443 | \
            openssl x509 -pubkey -noout | \
            openssl pkey -pubin -outform der | \
            openssl dgst -sha256 -binary | base64
    -->

</network-security-config>
