# GastroCore backoffice — environment variables
# Copy to `.env.local` and fill in real values.

# Backend API base URL (server-side calls)
API_BASE_URL=https://api.gastrocore.ch/api/v1

# Public mirror (browser/client). In dev set to http://localhost:8080/api/v1
NEXT_PUBLIC_API_URL=https://api.gastrocore.ch/api/v1

# WebSocket (orders live update — Cloudflare DNS-only, gray cloud, direct to origin)
NEXT_PUBLIC_WS_URL=wss://ws.gastrocore.ch

# Auth cookie secret (32+ char random) — middleware için
AUTH_COOKIE_SECRET=change-me-to-a-32-char-random-string

# Default tenant id (opsiyonel — login sonrası user'dan gelir)
# DEFAULT_TENANT_ID=

# Node env
NODE_ENV=development
