# GastroCore — production environment (infra/deploy/docker-compose.prod.yml)
#
# Copy to `.env` and fill with real values. `.env` is git-ignored.
#
#   cp infra/deploy/.env.example infra/deploy/.env
#   nano infra/deploy/.env
#   docker compose -f infra/deploy/docker-compose.prod.yml --env-file infra/deploy/.env up -d
#
# v1.1 roadmap: migrate these to Vault / cloud secrets manager — see
# docs/DEPLOYMENT.md and SECURITY.md for rotation policy. Until then,
# treat this file as the single source of truth for production secrets.
# ---------------------------------------------------------------------------

# Postgres — primary datastore password. Min 32 chars, alnum + symbol.
# Generate: `openssl rand -base64 32`
DB_PASSWORD=

# JWT signing secret for the Go server. Min 32 chars (HS256).
# Generate: `openssl rand -base64 48`
# Rotating this invalidates every issued token — force re-login on all clients.
JWT_SECRET=

# Ed25519 signing key (base64) used by the license issuer.
# The public half ships embedded in the Flutter apps.
# Generate: `go run server/scripts/genkey.go` (writes priv + pub)
LICENSE_SIGNING_KEY=

# Optional — Sentry DSN for server-side crash/log capture.
# SENTRY_DSN=
