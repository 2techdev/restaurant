# Server
PORT=8080
ENV=development
LOG_LEVEL=debug

# CORS — comma-separated list of allowed origins.
# Use "*" for local development only. Set specific origins in production:
# CORS_ORIGINS=https://pos.example.com,https://admin.example.com
CORS_ORIGINS=*

# Database
DATABASE_URL=postgres://gastrocore:gastrocore@localhost:5432/gastrocore?sslmode=disable

# JWT
JWT_SECRET=change-me-in-production-use-256-bit-random
JWT_EXPIRY=24h

# License
LICENSE_SIGNING_KEY=change-me-ed25519-private-key

# Fiskaly (Germany - Phase 4)
FISKALY_API_KEY=
FISKALY_API_SECRET=
FISKALY_ENV=test

# ERPNext (Phase 9)
ERPNEXT_URL=
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
