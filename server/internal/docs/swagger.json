{
  "openapi": "3.0.3",
  "info": {
    "title": "GastroCore API",
    "description": "Restaurant POS & Online Ordering Backend API",
    "version": "0.1.0",
    "contact": {
      "name": "GastroCore",
      "email": "dev@gastrocore.io"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local development"
    }
  ],
  "tags": [
    {"name": "auth",    "description": "Authentication & JWT tokens"},
    {"name": "online",  "description": "Public online ordering (no auth)"},
    {"name": "menu",    "description": "Menu management (auth required)"},
    {"name": "orders",  "description": "Order management"},
    {"name": "kds",     "description": "Kitchen Display System"},
    {"name": "sync",    "description": "Offline sync push/pull"},
    {"name": "admin",   "description": "Organization/store/user management"},
    {"name": "health",  "description": "Service health"}
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code":    {"type": "string"},
          "message": {"type": "string"},
          "details": {}
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token":  {"type": "string"},
          "refresh_token": {"type": "string"},
          "expires_in":    {"type": "integer"},
          "token_type":    {"type": "string", "example": "Bearer"}
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id":            {"type": "string", "format": "uuid"},
          "tenant_id":     {"type": "string"},
          "name":          {"type": "string"},
          "display_order": {"type": "integer"},
          "color":         {"type": "string"},
          "icon":          {"type": "string"},
          "is_active":     {"type": "boolean"}
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id":            {"type": "string", "format": "uuid"},
          "tenant_id":     {"type": "string"},
          "category_id":   {"type": "string"},
          "name":          {"type": "string"},
          "description":   {"type": "string"},
          "price":         {"type": "integer", "description": "Price in cents"},
          "tax_group":     {"type": "string"},
          "is_active":     {"type": "boolean"},
          "display_order": {"type": "integer"}
        }
      },
      "OnlineOrderRequest": {
        "type": "object",
        "required": ["restaurant_id", "order_type", "items"],
        "properties": {
          "restaurant_id": {"type": "string"},
          "order_type":    {"type": "string", "enum": ["dine_in","takeaway"]},
          "table_number":  {"type": "integer"},
          "customer_name": {"type": "string"},
          "notes":         {"type": "string"},
          "channel":       {"type": "string", "enum": ["qr","web","kiosk"]},
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["product_id","product_name","quantity","unit_price"],
              "properties": {
                "product_id":   {"type": "string"},
                "product_name": {"type": "string"},
                "quantity":     {"type": "integer"},
                "unit_price":   {"type": "integer"},
                "notes":        {"type": "string"}
              }
            }
          }
        }
      },
      "SyncEvent": {
        "type": "object",
        "properties": {
          "id":         {"type": "string"},
          "tenant_id":  {"type": "string"},
          "device_id":  {"type": "string"},
          "table_name": {"type": "string"},
          "record_id":  {"type": "string"},
          "operation":  {"type": "string", "enum": ["insert","update","delete"]},
          "payload":    {"type": "object"},
          "created_at": {"type": "string", "format": "date-time"}
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["health"],
        "summary": "Service health check",
        "responses": {
          "200": {"description": "Healthy"},
          "503": {"description": "Degraded"}
        }
      }
    },
    "/docs/swagger.json": {
      "get": {
        "tags": ["health"],
        "summary": "OpenAPI specification",
        "responses": {"200": {"description": "OpenAPI JSON"}}
      }
    },
    "/api/v1/auth/device/register": {
      "post": {
        "tags": ["auth"],
        "summary": "Register a POS/KDS device",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["tenant_id","device_name","license_key"],
                "properties": {
                  "tenant_id":   {"type": "string"},
                  "device_name": {"type": "string"},
                  "device_type": {"type": "string", "enum": ["pos","kds","kiosk","waiter"]},
                  "license_key": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "201": {"description": "Device registered, returns device_id and device_token"}
        }
      }
    },
    "/api/v1/auth/device/token": {
      "post": {
        "tags": ["auth"],
        "summary": "Exchange device token for JWT",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["device_id","device_token"],
                "properties": {
                  "device_id":    {"type": "string"},
                  "device_token": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "JWT tokens", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/TokenResponse"}}}}
        }
      }
    },
    "/api/v1/auth/admin/login": {
      "post": {
        "tags": ["auth"],
        "summary": "Admin dashboard login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email","password"],
                "properties": {
                  "email":    {"type": "string", "format": "email"},
                  "password": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "JWT tokens + user profile"}
        }
      }
    },
    "/api/v1/auth/token/refresh": {
      "post": {
        "tags": ["auth"],
        "summary": "Refresh access token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refresh_token"],
                "properties": {
                  "refresh_token": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "New token pair"}
        }
      }
    },
    "/api/v1/online/menu/{restaurant_id}": {
      "get": {
        "tags": ["online"],
        "summary": "Get public menu for QR ordering",
        "parameters": [
          {"name": "restaurant_id", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Full menu with categories, products, and modifier groups"},
          "404": {"description": "Restaurant not found"}
        }
      }
    },
    "/api/v1/online/orders": {
      "post": {
        "tags": ["online"],
        "summary": "Place an online order",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {"schema": {"$ref": "#/components/schemas/OnlineOrderRequest"}}
          }
        },
        "responses": {
          "201": {"description": "Order created"},
          "400": {"description": "Validation error"}
        }
      }
    },
    "/api/v1/online/orders/{order_id}/status": {
      "get": {
        "tags": ["online"],
        "summary": "Poll order status",
        "parameters": [
          {"name": "order_id", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Order status"},
          "404": {"description": "Order not found"}
        }
      }
    },
    "/api/v1/menu/categories": {
      "get": {
        "tags": ["menu"],
        "summary": "List categories",
        "security": [{"bearerAuth": []}],
        "responses": {"200": {"description": "Paginated categories"}}
      },
      "post": {
        "tags": ["menu"],
        "summary": "Create category",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {"schema": {"$ref": "#/components/schemas/Category"}}
          }
        },
        "responses": {"201": {"description": "Category created"}}
      }
    },
    "/api/v1/menu/categories/{id}": {
      "put": {
        "tags": ["menu"],
        "summary": "Update category",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {"200": {"description": "Updated"}, "404": {"description": "Not found"}}
      },
      "delete": {
        "tags": ["menu"],
        "summary": "Delete category",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {"204": {"description": "Deleted"}, "404": {"description": "Not found"}}
      }
    },
    "/api/v1/menu/products": {
      "get": {
        "tags": ["menu"],
        "summary": "List products",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "category_id", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "Paginated products"}}
      },
      "post": {
        "tags": ["menu"],
        "summary": "Create product",
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Product"}}}
        },
        "responses": {"201": {"description": "Product created"}}
      }
    },
    "/api/v1/menu/products/{id}": {
      "put": {
        "tags": ["menu"],
        "summary": "Update product",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {"200": {"description": "Updated"}}
      },
      "delete": {
        "tags": ["menu"],
        "summary": "Delete product",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {"204": {"description": "Deleted"}}
      }
    },
    "/api/v1/menu/modifiers": {
      "get": {
        "tags": ["menu"],
        "summary": "List modifier groups",
        "security": [{"bearerAuth": []}],
        "parameters": [
          {"name": "product_id", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "Modifier groups with modifiers"}}
      }
    },
    "/api/v1/kds/tickets": {
      "get": {
        "tags": ["kds"],
        "summary": "List open kitchen tickets",
        "security": [{"bearerAuth": []}],
        "responses": {"200": {"description": "Active kitchen tickets"}}
      }
    },
    "/api/v1/kds/items/{id}/status": {
      "put": {
        "tags": ["kds"],
        "summary": "Update item KDS status",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {"type": "string", "enum": ["preparing","ready","served"]}
                }
              }
            }
          }
        },
        "responses": {"200": {"description": "Status updated"}}
      }
    },
    "/api/v1/kds/tickets/{id}/status": {
      "put": {
        "tags": ["kds"],
        "summary": "Update all items in a ticket",
        "security": [{"bearerAuth": []}],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {"200": {"description": "Updated"}}
      }
    },
    "/ws/kds": {
      "get": {
        "tags": ["kds"],
        "summary": "KDS WebSocket — real-time kitchen ticket updates",
        "parameters": [
          {"name": "tenant_id", "in": "query", "required": true, "schema": {"type": "string"}},
          {"name": "device_id", "in": "query", "required": true, "schema": {"type": "string"}},
          {"name": "station",   "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {"101": {"description": "WebSocket upgrade"}}
      }
    },
    "/api/v1/sync/push": {
      "post": {
        "tags": ["sync"],
        "summary": "Push local changes to server",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["device_id","tenant_id","events"],
                "properties": {
                  "device_id": {"type": "string"},
                  "tenant_id": {"type": "string"},
                  "events": {"type": "array", "items": {"$ref": "#/components/schemas/SyncEvent"}}
                }
              }
            }
          }
        },
        "responses": {"200": {"description": "Accepted/rejected counts"}}
      }
    },
    "/api/v1/sync/pull": {
      "get": {
        "tags": ["sync"],
        "summary": "Pull remote changes",
        "parameters": [
          {"name": "device_id", "in": "query", "required": true, "schema": {"type": "string"}},
          {"name": "tenant_id", "in": "query", "required": true, "schema": {"type": "string"}},
          {"name": "cursor",    "in": "query", "schema": {"type": "string"}},
          {"name": "limit",     "in": "query", "schema": {"type": "integer"}}
        ],
        "responses": {"200": {"description": "Events and cursor"}}
      }
    },
    "/api/v1/sync/status": {
      "get": {
        "tags": ["sync"],
        "summary": "Sync health status",
        "parameters": [
          {"name": "device_id", "in": "query", "required": true, "schema": {"type": "string"}},
          {"name": "tenant_id", "in": "query", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {"200": {"description": "Sync status info"}}
      }
    },
    "/ws/sync": {
      "get": {
        "tags": ["sync"],
        "summary": "Sync WebSocket — real-time change notifications",
        "parameters": [
          {"name": "device_id", "in": "query", "required": true, "schema": {"type": "string"}},
          {"name": "tenant_id", "in": "query", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {"101": {"description": "WebSocket upgrade"}}
      }
    },
    "/api/v1/admin/organization": {
      "get": {
        "tags": ["admin"],
        "summary": "Get organization",
        "security": [{"bearerAuth": []}],
        "responses": {"200": {"description": "Organization details"}}
      },
      "put": {
        "tags": ["admin"],
        "summary": "Update organization",
        "security": [{"bearerAuth": []}],
        "responses": {"200": {"description": "Updated organization"}}
      }
    },
    "/api/v1/admin/brands": {
      "get":  {"tags": ["admin"], "summary": "List brands", "security": [{"bearerAuth": []}], "responses": {"200": {"description": "Brands"}}},
      "post": {"tags": ["admin"], "summary": "Create brand", "security": [{"bearerAuth": []}], "responses": {"201": {"description": "Created"}}}
    },
    "/api/v1/admin/stores": {
      "get":  {"tags": ["admin"], "summary": "List stores", "security": [{"bearerAuth": []}], "responses": {"200": {"description": "Stores"}}},
      "post": {"tags": ["admin"], "summary": "Create store", "security": [{"bearerAuth": []}], "responses": {"201": {"description": "Created"}}}
    },
    "/api/v1/admin/users": {
      "get":  {"tags": ["admin"], "summary": "List admin users", "security": [{"bearerAuth": []}], "responses": {"200": {"description": "Users"}}},
      "post": {"tags": ["admin"], "summary": "Create admin user", "security": [{"bearerAuth": []}], "responses": {"201": {"description": "Created"}}}
    },
    "/api/v1/admin/dashboard": {
      "get": {"tags": ["admin"], "summary": "Organization dashboard stats", "security": [{"bearerAuth": []}], "responses": {"200": {"description": "Dashboard"}}}
    }
  }
}
